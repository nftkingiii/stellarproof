{
  "rewrites": [
    {
      "source": "/",
      "destination": "/app/index.html"
    },
    {
      "source": "/proof.html",
      "destination": "/app/proof.html"
    },
    {
      "source": "/brand-review.html",
      "destination": "/app/brand-review.html"
    },
    {
      "source": "/styles.css",
      "destination": "/app/styles.css"
    },
    {
      "source": "/script.js",
      "destination": "/app/script.js"
    },
    {
      "source": "/assets/:path*",
      "destination": "/app/assets/:path*"
    },
    {
      "source": "/proofs/:path*",
      "destination": "/app/proofs/:path*"
    }
  ]
}
